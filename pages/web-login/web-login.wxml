<view class="container">
  <view class="auth-card">
    <image class="logo" src="/assets/miniapp/android/icon-xxhdpi.png" mode="aspectFit"></image>
    <view class="title">成绩雷达</view>
    <view class="subtitle">网页版登录确认</view>
    
    <view class="device-info">
      <view class="info-label">正在尝试在其他设备上登录成绩雷达</view>
      <view class="info-desc">为了您的数据安全，请确认是您本人的操作</view>
    </view>

    <view class="btn-group">
      <button class="btn-primary" bindtap="confirmLogin" loading="{{loading}}">确认授权登录</button>
      <button class="btn-default" bindtap="cancelLogin">取消登录</button>
    </view>
  </view>
</view>
