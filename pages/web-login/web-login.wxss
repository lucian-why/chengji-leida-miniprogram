.container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background-color: #faf8f5;
  padding: 40rpx;
  box-sizing: border-box;
}

.auth-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888888;
  margin-bottom: 60rpx;
}

.device-info {
  width: 100%;
  background: #f7f9fa;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 60rpx;
  text-align: center;
}

.info-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.info-desc {
  font-size: 24rpx;
  color: #999999;
}

.btn-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.btn-primary {
  width: 100% !important;
  height: 90rpx;
  line-height: 90rpx;
  background: #10a37f;
  color: #ffffff;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 0;
}

.btn-primary::after {
  border: none;
}

.btn-default {
  width: 100% !important;
  height: 90rpx;
  line-height: 90rpx;
  background: #f2f2f2;
  color: #666666;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 0;
}

.btn-default::after {
  border: none;
}
